APP_NAME="Api PHP Symfony"
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share

DB_HOST=api-php-symfony-db
DB_PORT=3306
DB_DATABASE=db
DB_USERNAME=user
DB_PASSWORD=1234

DEFAULT_URI=http://localhost

DATABASE_URL="mysql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}?serverVersion=8.0&charset=utf8mb4"
###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
